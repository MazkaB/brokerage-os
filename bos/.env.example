# =====================================================
# Brokerage OS - environment variables (copy to .env)
# =====================================================

# Vertex AI (LLM + embeddings) - uses ADC, NO API KEY NEEDED.
# Run: gcloud auth application-default login
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Server
BOS_HOST=0.0.0.0
BOS_PORT=8000
BOS_LOG_LEVEL=INFO

# Storage (local SQLite + Chroma file dirs)
BOS_DB_PATH=./app/data/bos.db
BOS_CHROMA_PATH=./app/data/chroma
BOS_KB_PATH=./knowledge_base

# Security
BOS_API_KEY=bos-local-dev-key-CHANGE-ME
BOS_JWT_SECRET=bos-local-jwt-secret-CHANGE-ME
BOS_ENCRYPTION_KEY=bos-local-encryption-key-32bytes

# Human-in-the-loop
BOS_APPROVAL_TIMEOUT_SECONDS=1800

# LangSmith (optional - disabled by default; we use local observability)
LANGSMITH_TRACING=false
